<section class="hero"><div class="hero-bg-overlay"></div><div class="container"><div class="hero-content"><span class="hero-subtitle">{{ copy.hero.eyebrow }}</span><h1 class="hero-title">{{ copy.hero.title }}</h1><p class="hero-desc">{{ copy.hero.text }}</p><div class="hero-proof" aria-label="{{ copy.hero.eyebrow }}">{% for item in copy.hero.proof %}<span>{{ item | interpolate(locale) | safe }}</span>{% endfor %}</div><div class="hero-actions"><a href="{{ localeUrl('contact', locale) }}" class="btn btn-gold">{{ copy.hero.primary }}</a><a href="{{ localeUrl('contact', locale) }}?request=samples#inquiry-form" class="btn btn-outline">{{ copy.hero.secondary }}</a></div></div></div></section>
<section class="factory-metrics"><div class="container"><div class="factory-metrics-grid">{% set metrics = [site.manufacturer.factoryArea.display, fact(locale, 'founded'), fact(locale, 'workshop'), site.manufacturer.fragranceFormulaLibrary.display] %}{% for label in copy.metricLabels %}<div class="factory-metric"><strong>{{ metrics[loop.index0] }}</strong><span>{{ label }}</span></div>{% endfor %}</div></div></section>
<section class="section-padding product-categories-section" id="product-capabilities"><div class="container"><div class="text-center"><span class="section-kicker">{{ copy.categories.kicker }}</span><h2 class="section-title">{{ copy.categories.title }}</h2><p class="section-lead">{{ copy.categories.text }}</p></div><div class="categories-grid">{% for item in copy.categories.items %}<a class="category-card" id="{{ item[0] }}" href="{{ localeUrl('contact', locale) }}"><img class="category-bg" src="{{ ('assets/images/home-products/' + item[1]) | assetUrl }}" alt="{{ item[2] }}" width="1122" height="1402" loading="lazy"><div class="category-overlay"></div><div class="category-info"><span>{{ item[3] }}</span><h3>{{ item[4] }}</h3><p>{{ item[5] }}</p><span class="category-link">{{ copy.categories.link }}</span></div></a>{% endfor %}</div>{% if copy.categories.cta %}<div class="categories-cta text-center"><p>{{ copy.categories.question }}</p><a href="{{ localeUrl('contact', locale) }}" class="btn btn-outline">{{ copy.categories.cta }}</a></div>{% endif %}</div></section>
<section class="section-padding cooperation-section" id="cooperation-models"><div class="container"><div class="text-center"><span class="section-kicker">{{ copy.models.kicker }}</span><h2 class="section-title">{{ copy.models.title }}</h2><p class="section-lead">{{ copy.models.text }}</p></div><div class="home-models-grid">{% for model in copy.models.items %}<article class="home-model-card{% if model.featured %} featured{% endif %}">{% if model.badge %}<div class="model-card-topline"><span class="model-code">0{{ loop.index }}</span><span class="model-speed">{{ model.badge }}</span></div>{% endif %}<h3>{{ model.title }}</h3><p>{{ model.text }}</p><div class="model-specs">{% for spec in model.specs %}<div><span>{{ spec[0] }}</span><strong>{{ spec[1] | interpolate(locale) | safe }}</strong></div>{% endfor %}</div><a href="{{ localeUrl('process', locale) }}" class="model-link">{{ model.link }}</a></article>{% endfor %}</div></div></section>
<section class="section-padding home-process-section" id="home-process"><div class="container"><div class="home-process-header"><div><span class="section-kicker">{{ copy.process.kicker }}</span><h2 class="section-title">{{ copy.process.title }}</h2></div><p>{{ copy.process.text }}</p></div><ol class="home-process-grid">{% for item in copy.process.items %}<li class="home-process-step"><span class="process-index">0{{ loop.index }}</span><h3>{{ item[0] }}</h3><p>{{ item[1] }}</p></li>{% endfor %}</ol><div class="home-process-action"><a href="{{ localeUrl('process', locale) }}" class="btn btn-outline">{{ copy.process.cta }}</a></div></div></section>
{% if copy.extended %}{% set x = copy.extended %}
<section class="section-padding fragrance-development-section" id="fragrance-development"><div class="container"><div class="feature-split"><div class="feature-media"><img src="{{ 'assets/images/home-sections/fragrance-development.webp' | assetUrl }}" alt="Fragrance development workbench" width="1536" height="1024" loading="lazy"></div><div class="feature-content"><span class="section-kicker">{{ x.fragrance.kicker }}</span><h2 class="section-title">{{ x.fragrance.title }}</h2><p class="feature-intro">{{ x.fragrance.text }}</p><div class="fragrance-family-grid">{% for item in x.fragrance.families %}<span>{{ item }}</span>{% endfor %}</div><ul class="feature-checklist">{% for item in x.fragrance.checks %}<li>{{ item }}</li>{% endfor %}</ul><a href="{{ localeUrl('contact', locale) }}" class="btn btn-gold">{{ x.fragrance.cta }}</a></div></div></div></section>
<section class="section-padding manufacturing-section" id="manufacturing-capability"><div class="container"><div class="manufacturing-grid"><div class="manufacturing-content"><span class="section-kicker">{{ x.manufacturing.kicker }}</span><h2 class="section-title">{{ x.manufacturing.title }}</h2><p class="feature-intro">{{ x.manufacturing.text }}</p><div class="capability-list">{% for item in x.manufacturing.items %}<div><span>0{{ loop.index }}</span><p>{{ item }}</p></div>{% endfor %}</div><a href="{{ localeUrl('contact', locale) }}" class="btn btn-outline">{{ x.manufacturing.cta }}</a></div><div class="manufacturing-media"><img src="{{ 'assets/images/home-sections/manufacturing-facility.webp' | assetUrl }}" alt="Perfume manufacturing facility" width="1920" height="891" loading="lazy"><div class="manufacturing-caption"><strong>{{ x.manufacturing.caption }}</strong><span>{{ x.manufacturing.meta }}</span></div></div></div></div></section>
<section class="section-padding quality-section" id="quality-control"><div class="container"><div class="quality-intro-grid"><div><span class="section-kicker">{{ x.quality.kicker }}</span><h2 class="section-title">{{ x.quality.title }}</h2><p class="feature-intro">{{ x.quality.text }}</p></div><div class="quality-image"><img src="{{ 'assets/images/home-sections/quality-control.webp' | assetUrl }}" alt="Perfume quality control" width="1536" height="1024" loading="lazy"></div></div><div class="quality-grid">{% for item in x.quality.items %}<article><span>0{{ loop.index }}</span><h3>{{ item[0] }}</h3><p>{{ item[1] }}</p></article>{% endfor %}</div></div></section>
<section class="section-padding case-study-section" id="project-example"><div class="container"><div class="case-study-grid"><div class="case-study-media"><img src="{{ 'assets/images/home-sections/representative-project.webp' | assetUrl }}" alt="Representative private label perfume collection" width="1536" height="1024" loading="lazy"><span class="case-study-label">{{ x.caseStudy.label }}</span></div><div class="case-study-content"><span class="section-kicker">{{ x.caseStudy.kicker }}</span><h2 class="section-title">{{ x.caseStudy.title }}</h2><p class="feature-intro">{{ x.caseStudy.text }}</p><div class="case-study-stats">{% for stat in x.caseStudy.stats %}<div><strong>{{ stat[0] }}</strong><span>{{ stat[1] }}</span></div>{% endfor %}</div><ul class="feature-checklist">{% for item in x.caseStudy.checks %}<li>{{ item }}</li>{% endfor %}</ul><a href="{{ localeUrl('contact', locale) }}" class="btn btn-gold">{{ x.caseStudy.cta }}</a></div></div></div></section>
<section class="section-padding export-section" id="global-export"><div class="container"><div class="export-heading"><div><span class="section-kicker">{{ x.export.kicker }}</span><h2 class="section-title">{{ x.export.title }}</h2></div><p>{{ x.export.text }}</p></div><div class="export-regions">{% for item in x.export.regions %}<span>{{ item }}</span>{% endfor %}</div><div class="export-support-grid">{% for item in x.export.items %}<article><span>0{{ loop.index }}</span><h3>{{ item[0] }}</h3><p>{{ item[1] }}</p></article>{% endfor %}</div><p class="export-disclaimer">{{ x.export.note }}</p></div></section>
<section class="section-padding home-faq-section" id="home-faq"><div class="container"><div class="home-faq-grid"><div class="home-faq-intro"><span class="section-kicker">{{ x.faq.kicker }}</span><h2 class="section-title">{{ x.faq.title }}</h2><p class="feature-intro">{{ x.faq.text }}</p><a href="{{ localeUrl('qa', locale) }}" class="btn btn-outline">{{ x.faq.cta }}</a></div><div class="home-faq-list">{% for item in x.faq.items %}<details><summary>{{ item[0] }}</summary><p>{{ item[1] | interpolate(locale) | safe }}</p></details>{% endfor %}</div></div></div></section>
<section class="section-padding home-inquiry-section" id="inquiry"><div class="container"><div class="home-inquiry-grid"><div class="home-inquiry-copy"><span class="section-kicker">{{ x.inquiry.kicker }}</span><h2>{{ x.inquiry.title }}</h2><p>{{ x.inquiry.text }}</p><div class="inquiry-expectations">{% for item in x.inquiry.expectations %}<div><strong>{{ item[0] }}</strong><span>{{ item[1] }}</span></div>{% endfor %}</div><p class="inquiry-email-fallback">{{ x.inquiry.email }} <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a></p></div><div class="home-inquiry-form-card">{% set form = x.inquiry.form %}<form id="inquiry-form"><div class="form-row"><div class="form-group"><label for="inquiry-name">{{ form.labels.name }}</label><input type="text" id="inquiry-name" class="form-control" autocomplete="name" required></div><div class="form-group"><label for="inquiry-company">{{ form.labels.company }}</label><input type="text" id="inquiry-company" class="form-control" autocomplete="organization"></div></div><div class="form-row"><div class="form-group"><label for="inquiry-email">{{ form.labels.email }}</label><input type="email" id="inquiry-email" class="form-control" autocomplete="email" required></div><div class="form-group"><label for="inquiry-country">{{ form.labels.country }}</label><input type="text" id="inquiry-country" class="form-control" autocomplete="country-name" required></div></div><div class="form-group"><label for="inquiry-qty">{{ form.labels.quantity }}</label><select id="inquiry-qty" class="form-control" required><option value="">{{ form.select }}</option>{% for option in form.quantities %}{% if option[0] == 'low' %}<option value="{{ site.services.lowQuantityReview.optionValue }}">{{ option[1] }}</option>{% elif option[0] == 'private' %}<option value="{{ site.services.quantityRanges.privateLabel.value }}">{{ site.services.quantityRanges.privateLabel.label }}</option>{% elif option[0] == 'custom' %}<option value="{{ site.services.quantityRanges.customProject.value }}">{{ site.services.quantityRanges.customProject.label }}</option>{% else %}<option value="{{ option[0] }}">{{ option[1] }}</option>{% endif %}{% endfor %}</select></div><fieldset class="form-group inquiry-services"><legend>{{ form.labels.services }}</legend><div class="checkbox-group">{% for service in form.services %}{% if loop.index <= 4 %}<label class="checkbox-label"><input type="checkbox" name="service" value="{{ service[0] }}"> {{ service[1] }}</label>{% endif %}{% endfor %}</div></fieldset><div class="form-group"><label for="inquiry-details">{{ form.labels.details }}</label><textarea id="inquiry-details" class="form-control" rows="4" placeholder="{{ form.detailsPlaceholder }}"></textarea></div><button type="submit" class="btn btn-gold home-inquiry-submit">{{ form.submit }}</button><p class="form-privacy-note">{{ form.note }}</p></form></div></div></div></section>
{% endif %}
{% if copy.final %}<section class="section-padding final-cta"><div class="container text-center"><h2>{{ copy.final.title }}</h2><p>{{ copy.final.text }}</p><a href="{{ localeUrl('contact', locale) }}" class="btn btn-gold">{{ copy.final.cta }}</a></div></section>{% endif %}
