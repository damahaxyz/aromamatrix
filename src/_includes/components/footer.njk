<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col footer-brand">
        <a href="{{ localeUrl('index', locale) }}" class="footer-brand-link" aria-label="{{ site.brand.name }}">
          <img src="{{ 'assets/images/brand/aromamatrix-wordmark.svg' | assetUrl }}" alt="{{ site.brand.name }} {{ site.brand.descriptor }}" class="footer-brand-logo" width="1200" height="300">
        </a>
        <p>{{ t(locale, 'footer.description') }}</p>
      </div>
      <div class="footer-col">
        <h4>{{ t(locale, 'footer.services') }}</h4>
        <ul>
          <li><a href="{{ localeUrl('process', locale) }}#oem">OEM</a></li>
          <li><a href="{{ localeUrl('process', locale) }}#odm">ODM</a></li>
          <li><a href="{{ localeUrl('process', locale) }}#private-label">Private Label</a></li>
          <li><a href="{{ localeUrl('index', locale) }}#packaging-solutions">Packaging</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>{{ t(locale, 'footer.quickLinks') }}</h4>
        <ul>
          <li><a href="{{ localeUrl('about', locale) }}">{{ t(locale, 'nav.about') }}</a></li>
          <li><a href="{{ localeUrl('qa', locale) }}">{{ t(locale, 'nav.faq') }}</a></li>
          <li><a href="{{ localeUrl('blog', locale) }}">{{ t(locale, 'nav.blog') }}</a></li>
          <li><a href="{{ localeUrl('contact', locale) }}">{{ t(locale, 'nav.contact') }}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>{{ t(locale, 'footer.contact') }}</h4>
        <p class="footer-contact-row">
          <strong>{{ t(locale, 'footer.projectDesk') }}:</strong>
          <span>{{ t(locale, 'footer.projectDeskLocation') }}</span>
        </p>
        <p class="footer-contact-row">
          <strong>{{ t(locale, 'footer.email') }}:</strong>
          <a class="footer-contact-link" href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
        </p>
        <p class="footer-contact-row">
          <strong>{{ t(locale, 'footer.whatsapp') }}:</strong>
          <a class="footer-contact-link" href="{{ site.contact.whatsapp.url }}" target="_blank" rel="noopener noreferrer">{{ site.contact.whatsapp.display }}</a>
        </p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 {{ site.brand.name }}
        {{ site.brand.descriptor }}. {{ t(locale, 'footer.rights') }} (ISO 22716 &amp; GMPC)</p>
      <p class="footer-legal-links">
        <a href="{{ localeUrl('qa', locale) }}#shipping">{{ t(locale, 'footer.shipping') }}</a>
        <span aria-hidden="true">|</span>
        <a href="{{ localeUrl('terms', locale) }}">{{ t(locale, 'footer.terms') }}</a>
        <span aria-hidden="true">|</span>
        <a href="{{ localeUrl('privacy', locale) }}">{{ t(locale, 'footer.privacy') }}</a>
      </p>
    </div>
  </div>
</footer>
