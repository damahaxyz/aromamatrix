<section class="service-hero"><img src="{{ 'assets/images/about/factory/filling-line.webp' | assetUrl }}" alt="{{ site.brand.name }} fragrance filling equipment" width="1400" height="637" fetchpriority="high" decoding="async"><div class="service-hero-overlay"></div><div class="container"><div class="service-hero-content"><span>{{ copy.hero.eyebrow }}</span><h1>{{ copy.hero.title }}</h1><p>{{ copy.hero.text }}</p><div class="service-hero-actions"><a href="{{ localeUrl('contact', locale) }}" class="btn btn-gold">{{ copy.hero.primary }}</a><a href="#service-models" class="btn btn-outline">{{ copy.hero.secondary }}</a></div></div></div></section>
<section class="service-facts" aria-label="{{ copy.routesIntro.kicker }}"><div class="container"><div class="service-facts-grid">{% for label in copy.factLabels %}<div><strong>{{ copy.factValues[loop.index0] | interpolate(locale) | safe }}</strong><span>{{ label }}</span></div>{% endfor %}</div></div></section>
<section class="section-padding service-models-section" id="service-models"><div class="container"><div class="text-center service-section-intro"><span class="section-kicker">{{ copy.routesIntro.kicker }}</span><h2 class="section-title">{{ copy.routesIntro.title }}</h2><p class="section-lead">{{ copy.routesIntro.text }}</p></div><div class="service-route-grid">{% for route in copy.routes %}<article class="service-route-card" id="{{ route.id }}"><div class="service-route-topline"><span>{{ route.badge }}</span><strong>{{ route.quantity | interpolate(locale) | safe }}</strong></div><h3>{{ route.title }}</h3><p>{{ route.text }}</p><dl>{% for detail in route.details %}<div><dt>{{ detail[0] }}</dt><dd>{{ detail[1] }}</dd></div>{% endfor %}</dl><a href="{{ localeUrl('contact', locale) }}" class="service-card-link">{{ route.link }}</a></article>{% endfor %}</div><p class="service-terms-note">{{ copy.terms }}</p></div></section>
{% if copy.options %}<section class="section-padding processing-options-section"><div class="container"><div class="service-split-heading"><div><span class="section-kicker">{{ copy.options.kicker }}</span><h2 class="section-title">{{ copy.options.title }}</h2></div><p>{{ copy.options.text }}</p></div><div class="processing-options-grid">{% for item in copy.options.items %}<article><span>0{{ loop.index }}</span><h3>{{ item[0] }}</h3><p>{{ item[1] }}</p><small>{{ item[2] }}</small></article>{% endfor %}</div></div></section>{% endif %}
<section class="section-padding custom-process-section" id="customization-process"><div class="container"><div class="custom-process-layout"><div class="custom-process-visual"><img src="{{ 'assets/images/about/factory/compounding-workshop.webp' | assetUrl }}" alt="Perfume compounding equipment" width="1400" height="1050" loading="lazy"><div><strong>{{ copy.process.visualTitle }}</strong><span>{{ copy.process.visualMeta }}</span></div></div><div class="custom-process-content"><span class="section-kicker">{{ copy.process.kicker }}</span><h2 class="section-title">{{ copy.process.title }}</h2><ol class="custom-process-list">{% for item in copy.process.items %}<li{% if loop.index == 5 %} class="process-highlight"{% endif %}><span>0{{ loop.index }}</span><div><h3>{{ item[0] }}</h3><p>{{ item[1] }}</p></div></li>{% endfor %}</ol></div></div></div></section>
<section class="section-padding free-sample-section" id="free-samples"><div class="container"><div class="free-sample-layout"><div class="free-sample-media"><img src="{{ 'assets/images/about/factory/sample-showroom.webp' | assetUrl }}" alt="{{ site.brand.name }} sample showroom" width="1400" height="637" loading="lazy"><div><strong>{{ copy.samples.mediaTitle }}</strong><span>{{ copy.samples.mediaMeta }}</span></div></div><div class="free-sample-content"><span class="section-kicker">{{ copy.samples.kicker }}</span><h2 class="section-title">{{ copy.samples.title }}</h2><p class="free-sample-intro">{{ copy.samples.intro }}</p><div class="free-sample-facts">{% for label in copy.samples.labels %}<div><span>{{ label }}</span><strong>{{ copy.samples.values[loop.index0] | interpolate(locale) | safe }}</strong></div>{% endfor %}</div><ul class="free-sample-notes">{% for note in copy.samples.notes %}<li>{{ note }}</li>{% endfor %}</ul><a href="{{ localeUrl('contact', locale) }}?request=samples#inquiry-form" class="btn btn-gold">{{ copy.samples.cta }}</a></div></div></div></section>
{% if copy.operations %}<section class="section-padding available-operations-section"><div class="container"><div class="text-center service-section-intro"><span class="section-kicker">{{ copy.operations.kicker }}</span><h2 class="section-title">{{ copy.operations.title }}</h2><p class="section-lead">{{ copy.operations.text }}</p></div><div class="operations-grid">{% for item in copy.operations.items %}<div><span>0{{ loop.index }}</span><strong>{{ item[0] }}</strong><small>{{ item[1] }}</small></div>{% endfor %}</div></div></section>{% endif %}
{% if copy.faq %}<section class="section-padding service-faq-section"><div class="container"><div class="service-split-heading"><div><span class="section-kicker">{{ copy.faq.kicker }}</span><h2 class="section-title">{{ copy.faq.title }}</h2></div><p>{{ copy.faq.text }}</p></div><div class="service-faq-grid">{% for item in copy.faq.items %}<details open><summary>{{ item[0] }}</summary><p>{{ item[1] | interpolate(locale) | safe }}</p></details>{% endfor %}</div></div></section>{% endif %}
{% if copy.final %}<section class="service-final-cta"><div class="container"><div><span>{{ copy.final.eyebrow }}</span><h2>{{ copy.final.title }}</h2><p>{{ copy.final.text }}</p></div><a href="{{ localeUrl('contact', locale) }}" class="btn btn-gold">{{ copy.final.cta }}</a></div></section>{% endif %}
