<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <a href="{{ localeUrl('index', locale) }}" class="logo" style="margin-bottom: 20px; display: inline-block;">
          {{ site.brand.name }}<span>{{ site.brand.descriptor }}</span>
        </a>
        <p>{{ t(locale, 'footer.description') }}</p>
      </div>
      <div class="footer-col">
        <h4>{{ t(locale, 'footer.services') }}</h4>
        <ul>
          <li><a href="{{ localeUrl('process', locale) }}#oem">OEM</a></li>
          <li><a href="{{ localeUrl('process', locale) }}#odm">ODM</a></li>
          <li><a href="{{ localeUrl('process', locale) }}#private-label">Private Label</a></li>
          <li><a href="{{ localeUrl('index', locale) }}#packaging-solutions">Packaging</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>{{ t(locale, 'footer.quickLinks') }}</h4>
        <ul>
          <li><a href="{{ localeUrl('about', locale) }}">{{ t(locale, 'nav.about') }}</a></li>
          <li><a href="{{ localeUrl('qa', locale) }}">{{ t(locale, 'nav.faq') }}</a></li>
          <li><a href="{{ localeUrl('blog', locale) }}">{{ t(locale, 'nav.blog') }}</a></li>
          <li><a href="{{ localeUrl('contact', locale) }}">{{ t(locale, 'nav.contact') }}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>{{ t(locale, 'footer.contact') }}</h4>
        <p style="margin-bottom: 10px;"><strong>{{ t(locale, 'footer.projectDesk') }}:</strong> {{ t(locale, 'footer.projectDeskLocation') }}</p>
        <p style="margin-bottom: 10px;"><strong>{{ t(locale, 'footer.email') }}:</strong> <a href="mailto:{{ site.contact.email }}" style="color: var(--accent-green);">{{ site.contact.email }}</a></p>
        <p><strong>{{ t(locale, 'footer.whatsapp') }}:</strong> <a href="{{ site.contact.whatsapp.url }}" target="_blank" rel="noopener noreferrer" style="color: var(--accent-green); font-weight: 600;">{{ site.contact.whatsapp.display }}</a></p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 {{ site.brand.name }} {{ site.brand.descriptor }}. {{ t(locale, 'footer.rights') }} (ISO 22716 &amp; GMPC)</p>
      <p class="footer-legal-links">
        <a href="{{ localeUrl('qa', locale) }}#shipping">{{ t(locale, 'footer.shipping') }}</a><span aria-hidden="true">|</span>
        <a href="{{ localeUrl('terms', locale) }}">{{ t(locale, 'footer.terms') }}</a><span aria-hidden="true">|</span>
        <a href="{{ localeUrl('privacy', locale) }}">{{ t(locale, 'footer.privacy') }}</a>
      </p>
    </div>
  </div>
</footer>
