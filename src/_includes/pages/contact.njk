<section class="contact-hero"><div class="container"><div class="contact-hero-content"><span>{{ copy.hero.eyebrow | interpolate(locale) }}</span><h1>{{ copy.hero.title }}</h1><p>{{ copy.hero.text }}</p><div class="contact-hero-actions"><a href="#inquiry-form" class="btn btn-gold">{{ copy.hero.primary }}</a><a href="?request=samples#inquiry-form" class="btn btn-outline">{{ copy.hero.secondary }}</a></div><div class="contact-hero-proof" aria-label="{{ copy.hero.primary }}">{% for item in copy.hero.proof %}<span>{{ item | interpolate(locale) | safe }}</span>{% endfor %}</div></div></div></section>
<section class="section-padding contact-workspace"><div class="container"><div class="contact-grid"><aside class="contact-info-panel"><div class="contact-brand-block"><span>{{ copy.panel.eyebrow | interpolate(locale) }}</span><h2>{{ copy.panel.title }}</h2><p>{{ copy.panel.text | interpolate(locale) | safe }}</p></div><figure class="contact-team-image"><img src="{{ 'assets/images/about/factory/team-office.webp' | assetUrl }}" alt="{{ copy.panel.imageTitle }}" width="1400" height="637" loading="lazy"><figcaption><strong>{{ copy.panel.imageTitle }}</strong><span>{{ copy.panel.imageMeta }}</span></figcaption></figure><div class="contact-channel-list"><a class="contact-channel" href="{{ site.contact.whatsapp.url }}" target="_blank" rel="noopener noreferrer"><span class="contact-channel-mark whatsapp">WA</span><span><small>{{ copy.panel.whatsapp | interpolate(locale) }}</small><strong>{{ site.contact.whatsapp.display }}</strong><em>{{ copy.panel.whatsappAction }}</em></span></a><a class="contact-channel" href="mailto:{{ site.contact.email }}"><span class="contact-channel-mark">@</span><span><small>{{ copy.panel.email }}</small><strong>{{ site.contact.email }}</strong><em>{{ copy.panel.emailAction }}</em></span></a><div class="contact-channel contact-location"><span class="contact-channel-mark">CN</span><span><small>{{ copy.panel.location }}</small><strong>{{ site.contact.projectDeskLocation }}</strong><em>{{ copy.panel.locationAction }}</em></span></div></div>{% for card in copy.cards %}{% if card.kind == 'note' %}<div class="contact-shipping-note"><strong>{{ card.title }}</strong><p>{{ card.text | interpolate(locale) | safe }}</p></div>{% else %}<div class="contact-support-card {{ card.kind }}"><span>{{ card.eyebrow }}</span><h3>{{ card.title }}</h3><p>{{ card.text | interpolate(locale) | safe }}</p><a href="{{ localeUrl(card.linkPage, locale) }}{{ card.linkHash }}">{{ card.link }}</a></div>{% endif %}{% endfor %}</aside>
<div class="inquiry-form-card contact-project-form"><span class="form-kicker">{{ copy.form.eyebrow }}</span><h2>{{ copy.form.title }}</h2><p>{{ copy.form.intro }}</p><form id="inquiry-form"><div class="form-row"><div class="form-group"><label for="inquiry-name">{{ copy.form.labels.name }}</label><input type="text" id="inquiry-name" class="form-control" autocomplete="name" required></div><div class="form-group"><label for="inquiry-company">{{ copy.form.labels.company }}</label><input type="text" id="inquiry-company" class="form-control" autocomplete="organization"></div></div><div class="form-row"><div class="form-group"><label for="inquiry-email">{{ copy.form.labels.email }}</label><input type="email" id="inquiry-email" class="form-control" autocomplete="email" required></div><div class="form-group"><label for="inquiry-country">{{ copy.form.labels.country }}</label><input type="text" id="inquiry-country" class="form-control" autocomplete="country-name" required></div></div><div class="form-row"><div class="form-group"><label for="inquiry-product">{{ copy.form.labels.product }}</label><select id="inquiry-product" class="form-control" required><option value="">{{ copy.form.select }}</option>{% for option in copy.form.products %}<option value="{{ option[0] }}">{{ option[1] }}</option>{% endfor %}</select></div><div class="form-group"><label for="inquiry-qty">{{ copy.form.labels.quantity }}</label><select id="inquiry-qty" class="form-control" required><option value="">{{ copy.form.select }}</option>{% for option in copy.form.quantities %}{% if option[0] == 'low' %}<option value="{{ site.services.lowQuantityReview.optionValue }}">{{ option[1] }}</option>{% elif option[0] == 'private' %}<option value="{{ site.services.quantityRanges.privateLabel.value }}">{{ site.services.quantityRanges.privateLabel.label }}</option>{% elif option[0] == 'custom' %}<option value="{{ site.services.quantityRanges.customProject.value }}">{{ site.services.quantityRanges.customProject.label }}</option>{% else %}<option value="{{ option[0] }}">{{ option[1] }}</option>{% endif %}{% endfor %}</select></div></div><fieldset class="form-group inquiry-services"><legend>{{ copy.form.labels.services }}</legend><div class="checkbox-group">{% for service in copy.form.services %}<label class="checkbox-label"><input type="checkbox" name="service" value="{{ service[0] }}"> {{ service[1] }}</label>{% endfor %}</div></fieldset><div class="form-row"><div class="form-group"><label for="inquiry-packaging">{{ copy.form.labels.packaging }}</label><select id="inquiry-packaging" class="form-control">{% for option in copy.form.packaging %}<option value="{{ option[0] }}">{{ option[1] }}</option>{% endfor %}</select></div><div class="form-group"><label for="inquiry-launch">{{ copy.form.labels.launch }}</label><input type="text" id="inquiry-launch" class="form-control" placeholder="{{ copy.form.launchPlaceholder }}"></div></div><div class="form-group"><label for="inquiry-details">{{ copy.form.labels.details }}</label><textarea id="inquiry-details" class="form-control" rows="5" placeholder="{{ copy.form.detailsPlaceholder }}"></textarea></div><button type="submit" class="btn btn-gold contact-submit">{{ copy.form.submit }}</button><p class="contact-form-note">{{ copy.form.note }}</p></form></div></div></div></section>
